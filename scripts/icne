#!/usr/bin/env python3
"""icloud-nfs-exporter CLI tool."""

__version__ = "0.2.0"

import argparse
import os
import sys

# Allow importing icne_lib from the same directory as this script
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

from icne_lib import config as cfg  # noqa: E402
from icne_lib import diagnose, nfs, wizard  # noqa: E402


def cmd_setup(args):
    """Run the interactive setup wizard."""
    wizard.run(
        force=args.force,
        non_interactive=args.non_interactive,
    )


def cmd_add_folder(args):
    """Add an iCloud folder to the export list."""
    try:
        conf = cfg.add_folder(args.path, label=args.label)
    except FileNotFoundError as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)
    except ValueError as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)

    source = str(cfg.Path(args.path).expanduser().resolve())
    port = conf.get("nfs", {}).get("port", nfs.DEFAULT_PORT)

    print(f"Added folder:")
    print(f"  Source:  {source}")
    print(f"  Label:   {args.label or cfg.Path(source).name}")

    cmds = nfs.mount_command(port=port)
    print(f"\nTo serve via NFS:  icne exports")
    print(f"Then mount with:")
    print(f"  Linux:  {cmds['linux']}")
    print(f"  macOS:  {cmds['macos']}")


def cmd_remove_folder(args):
    """Remove a folder from the export list."""
    try:
        cfg.remove_folder(args.path)
        print(f"Removed: {args.path}")
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)


def cmd_list(args):
    """List configured folders."""
    conf = cfg.load_config()
    folders = conf.get("folders", [])
    if not folders:
        print("No folders configured. Run: icne add-folder <path>")
        return
    for f in folders:
        mount = cfg.mount_point_for(f["source"], conf)
        print(f"  {f.get('label', '?'):20s}  {f['source']}")
        print(f"  {'':20s}  → {mount}")


def cmd_diagnose(_args):
    """Run all diagnostic checks."""
    print("icloud-nfs-exporter diagnostics\n")
    checks = diagnose.run_all()
    for check in checks:
        print(check)
    passed = sum(1 for c in checks if c.ok)
    total = len(checks)
    print(f"\n  {passed}/{total} checks passed")
    if passed < total:
        sys.exit(1)


def cmd_exports(args):
    """Start, stop, or show status of the NFS server."""
    conf = cfg.load_config()
    folders = conf.get("folders", [])
    port = conf.get("nfs", {}).get("port", nfs.DEFAULT_PORT)
    socket_path = conf.get("general", {}).get("socket_path", cfg.DEFAULT_SOCKET)

    if args.stop:
        if nfs.stop_nfs_server():
            print("NFS server stopped.")
        else:
            print("NFS server is not running.")
        return

    if args.status:
        pid = nfs.nfs_server_pid()
        if pid:
            print(f"NFS server running (PID {pid}, port {port})")
            cmds = nfs.mount_command(port=port)
            print(f"\nMount with:")
            print(f"  Linux:  {cmds['linux']}")
            print(f"  macOS:  {cmds['macos']}")
        else:
            print("NFS server is not running.")
        return

    if not folders:
        print("No folders configured. Run: icne add-folder <path>", file=sys.stderr)
        sys.exit(1)

    # Use the first folder as the source directory
    source = folders[0]["source"]

    if nfs.nfs_server_is_running():
        print(f"NFS server already running (PID {nfs.nfs_server_pid()}).")
        cmds = nfs.mount_command(port=port)
        print(f"\nMount with:")
        print(f"  Linux:  {cmds['linux']}")
        print(f"  macOS:  {cmds['macos']}")
        return

    binary = nfs.nfs_server_binary()
    if binary is None:
        print("Error: nfs-server binary not found. Build with:", file=sys.stderr)
        print("  cd src/nfs && cargo build", file=sys.stderr)
        sys.exit(1)

    proc = nfs.start_nfs_server(source, port=port, socket_path=socket_path)
    if proc is None:
        print("Error: failed to start NFS server.", file=sys.stderr)
        sys.exit(1)

    print(f"NFS server started (PID {proc.pid}, port {port})")
    print(f"Serving: {source}")
    cmds = nfs.mount_command(port=port)
    print(f"\nMount with:")
    print(f"  Linux:  {cmds['linux']}")
    print(f"  macOS:  {cmds['macos']}")
    print(f"\nStop with: icne exports --stop")


def main():
    parser = argparse.ArgumentParser(
        prog="icne",
        description="icloud-nfs-exporter — manage iCloud Drive NFS exports",
    )
    parser.add_argument("--version", action="version",
                        version=f"%(prog)s {__version__}")
    sub = parser.add_subparsers(dest="command")

    # setup
    p_setup = sub.add_parser("setup", help="Interactive setup wizard")
    p_setup.add_argument("--force", action="store_true",
                         help="Overwrite existing config")
    p_setup.add_argument("--non-interactive", action="store_true",
                         help="Use defaults without prompting")

    # add-folder
    p_add = sub.add_parser("add-folder", help="Add an iCloud folder to export")
    p_add.add_argument("path", help="Path to iCloud folder")
    p_add.add_argument("--label", help="Human-readable label")

    # remove-folder
    p_rm = sub.add_parser("remove-folder", help="Remove a folder from exports")
    p_rm.add_argument("path", help="Path to remove")

    # list
    sub.add_parser("list", help="List configured folders")

    # diagnose
    sub.add_parser("diagnose", help="Run diagnostic checks")

    # exports
    p_exp = sub.add_parser("exports", help="Start/stop the NFS server")
    p_exp.add_argument("--stop", action="store_true",
                       help="Stop the NFS server")
    p_exp.add_argument("--status", action="store_true",
                       help="Show NFS server status and mount commands")

    args = parser.parse_args()
    if args.command is None:
        parser.print_help()
        sys.exit(1)

    commands = {
        "setup": cmd_setup,
        "add-folder": cmd_add_folder,
        "remove-folder": cmd_remove_folder,
        "list": cmd_list,
        "diagnose": cmd_diagnose,
        "exports": cmd_exports,
    }
    commands[args.command](args)


if __name__ == "__main__":
    main()
